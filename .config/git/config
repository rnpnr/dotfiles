[commit]
	gpgsign = true
[tag]
	gpgsign = true
[pull]
	rebase = true
[log]
	abbrevCommit = true
[diff]
	ignoreSubmodules = dirty
	algorithm = histogram
[sendemail]
	smtpserver = /usr/alt/bin/msmtp
[init]
	defaultBranch = master
[safe]
	directory = /usr/alt
[advice]
	skippedCherryPicks = false
[core]
	hooksPath    = ~/.config/git/hooks
